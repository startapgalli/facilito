# ──────────────────────────────────────────────
# FACILITO — Variables de Entorno
# ──────────────────────────────────────────────

# Puerto del servidor (default: 3000)
PORT=3000

# ── Capso / Proveedor WhatsApp ──
# Token compartido para validar webhooks entrantes (HMAC o Bearer)
CAPSO_WEBHOOK_SECRET=cambiar_en_produccion

# ── Groq ──
GROQ_API_KEY=gsk_tu-api-key-de-groq

# ── Base de Datos ──
# SQLite para desarrollo. En prod usar DATABASE_URL de PostgreSQL.
DATABASE_URL=file:./data/facilito.db

# ── Cifrado de Tokens ──
# Clave maestra AES-256-GCM (32 bytes en hex = 64 caracteres)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── Ambiente ──
NODE_ENV=development
